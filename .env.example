# Synchronizacja z chmurą (opcjonalna).
#
# Bez tych zmiennych aplikacja działa w trybie lokalnym — dane siedzą
# w localStorage przeglądarki, a interfejs logowania w ogóle się nie pojawia.
#
# Aby włączyć synchronizację:
#   1. Załóż projekt na https://supabase.com
#   2. Uruchom supabase/migrations/0001_app_state.sql w SQL Editorze
#   3. Skopiuj ten plik jako .env.local i uzupełnij wartości poniżej
#      (Project Settings → API)
#
# Klucz anon jest publiczny z założenia — bezpieczeństwo opiera się na RLS
# w bazie. NIGDY nie wstawiaj tu klucza service_role.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
